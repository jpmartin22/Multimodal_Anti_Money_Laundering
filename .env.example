# ── AML Multimodal Detection — Environment Variables ─────────────────────────
# Copy this file to .env and fill in values for your environment.
# .env is git-ignored; never commit real credentials.

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local filesystem (default inside the container):
MLFLOW_TRACKING_URI=file:///app/mlruns
# Remote server example:
# MLFLOW_TRACKING_URI=http://mlflow-server:5000

# ── Inference API ─────────────────────────────────────────────────────────────
# Risk score threshold above which a transaction is flagged
AML_THRESHOLD=0.5
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Grafana ───────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_in_production
GF_USERS_ALLOW_SIGN_UP=false

# ── Python runtime ────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
